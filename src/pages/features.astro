---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="FamlyBudget — Features"
  description="Discover all FamlyBudget features: dashboard, budgets, savings goals, recurring transactions, 90-day projection and much more."
>

<!-- ══════════════════════════════════════════════════════════
     HERO — Dark cinematic
══════════════════════════════════════════════════════════ -->
<section class="fp-hero">
  <div class="fp-hero-bg"></div>
  <div class="fp-hero-glow fp-hero-glow-1"></div>
  <div class="fp-hero-glow fp-hero-glow-2"></div>
  <div class="container fp-hero-inner">
    <div class="fp-hero-content">
      <div class="fp-eyebrow" data-i18n="fp_hero_eyebrow">✦ FamlyBudget 2026</div>
      <h1 class="fp-hero-h1" data-i18n-html="fp_hero_h1">Your budget.<br>Your family.<br><span class="fp-gradient-text">Finally together.</span></h1>
      <p class="fp-hero-sub" data-i18n="fp_hero_sub">
        One app to track every euro, plan every month and never be caught off guard again.
      </p>
      <div class="fp-hero-btns">
        <a href="#download" class="fp-btn fp-btn-primary" data-i18n="fp_hero_download">▶ &nbsp;Download Free</a>
        <a href="#cinema" class="fp-btn fp-btn-ghost" data-i18n="fp_hero_explore">Explore features ↓</a>
      </div>
    </div>
    <div class="fp-hero-phone-wrap">
      <div class="fp-hero-phone">
        <div class="fp-phone-notch"></div>
        <div class="fp-phone-inner">
          <div class="fp-phone-header">
            <div class="fp-ph-row">
              <span class="fp-ph-greeting" data-i18n="fp_ph_greeting">Hello, Fabrizio 👋</span>
              <span class="fp-ph-date" data-i18n="fp_ph_date">May 2026</span>
            </div>
            <div class="fp-ph-label" data-i18n="fp_ph_balance_label">Total balance</div>
            <div class="fp-ph-balance">€ 8,420.50</div>
            <div class="fp-ph-stats">
              <div class="fp-ph-stat">
                <span class="fp-ph-stat-icon fp-income-icon">↑</span>
                <div>
                  <div class="fp-ph-stat-label" data-i18n="fp_ph_income">Income</div>
                  <div class="fp-ph-stat-val fp-green">+€3,200</div>
                </div>
              </div>
              <div class="fp-ph-stat">
                <span class="fp-ph-stat-icon fp-expense-icon">↓</span>
                <div>
                  <div class="fp-ph-stat-label" data-i18n="fp_ph_expenses">Expenses</div>
                  <div class="fp-ph-stat-val fp-red">−€1,847</div>
                </div>
              </div>
            </div>
          </div>
          <div class="fp-phone-body">
            <div class="fp-survival-widget">
              <div class="fp-sw-title" data-i18n="fp_sw_title">Balance Projection — 90 days</div>
              <div class="fp-sw-chart">
                <svg viewBox="0 0 220 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="fp-sw-svg">
                  <path d="M0 48 C20 44 40 36 60 30 C80 24 90 28 100 26 C120 20 130 18 150 22 C170 26 180 34 200 32 L220 28" stroke="#3B82F6" stroke-width="2" fill="none"/>
                  <path d="M0 48 C20 44 40 36 60 30 C80 24 90 28 100 26 C120 20 130 18 150 22 C170 26 180 34 200 32 L220 28 L220 64 L0 64Z" fill="url(#sw-grad)" opacity="0.3"/>
                  <line x1="110" y1="0" x2="110" y2="64" stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="3,3"/>
                  <text x="113" y="10" font-size="7" fill="rgba(255,255,255,0.4)" font-family="Inter,sans-serif" data-i18n="fp_sw_today">Today</text>
                  <defs>
                    <linearGradient id="sw-grad" x1="0" y1="0" x2="0" y2="1">
                      <stop offset="0%" stop-color="#3B82F6"/>
                      <stop offset="100%" stop-color="#3B82F6" stop-opacity="0"/>
                    </linearGradient>
                  </defs>
                </svg>
              </div>
              <div class="fp-sw-footer">
                <span class="fp-sw-safe" data-i18n="fp_sw_safe">Safe to spend today</span>
                <span class="fp-sw-amount">€ 340</span>
              </div>
            </div>
            <div class="fp-phone-txlist">
              <div class="fp-ptx"><div class="fp-ptx-icon" style="background:#FEF3C7">🛒</div><div class="fp-ptx-info"><span data-i18n="fp_tx1">Grocery</span><span class="fp-ptx-cat" data-i18n="fp_tx1_cat">Food</span></div><span class="fp-ptx-amt fp-red">−€94</span></div>
              <div class="fp-ptx"><div class="fp-ptx-icon" style="background:#DCFCE7">💼</div><div class="fp-ptx-info"><span data-i18n="fp_tx2">Salary</span><span class="fp-ptx-cat" data-i18n="fp_tx2_cat">Income</span></div><span class="fp-ptx-amt fp-green">+€2,400</span></div>
              <div class="fp-ptx"><div class="fp-ptx-icon" style="background:#EDE9FE">🏠</div><div class="fp-ptx-info"><span data-i18n="fp_tx3">Rent</span><span class="fp-ptx-cat" data-i18n="fp_tx3_cat">Home</span></div><span class="fp-ptx-amt fp-red">−€750</span></div>
            </div>
          </div>
        </div>
      </div>
      <!-- floating badges -->
      <div class="fp-float fp-float-a fp-reveal">
        <span class="fp-float-icon">🎯</span>
        <div>
          <div class="fp-float-label" data-i18n="fp_float_goal">Vacation goal</div>
          <div class="fp-float-val">€1,200 / €3,000</div>
        </div>
      </div>
      <div class="fp-float fp-float-b fp-reveal">
        <span class="fp-float-icon fp-green">✓</span>
        <div>
          <div class="fp-float-label" data-i18n="fp_float_budget">Budget on track</div>
          <div class="fp-float-val">72% <span data-i18n="fp_float_used">used</span></div>
        </div>
      </div>
    </div>
  </div>
  <div class="fp-scroll-hint">
    <div class="fp-scroll-dot"></div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     VALUE PILLARS — Light section
══════════════════════════════════════════════════════════ -->
<section class="fp-pillars">
  <div class="container">
    <div class="fp-pillars-grid">
      <div class="fp-pillar fp-reveal">
        <div class="fp-pillar-icon">🔒</div>
        <h3 data-i18n="fp_pillar1_h">Your data, your rules</h3>
        <p data-i18n="fp_pillar1_p">Choose to keep everything on-device or sync to the cloud. You decide — anytime, no migration needed.</p>
      </div>
      <div class="fp-pillar fp-reveal">
        <div class="fp-pillar-icon">👨‍👩‍👧</div>
        <h3 data-i18n="fp_pillar2_h">Built for families and solo users</h3>
        <p data-i18n="fp_pillar2_p">Invite up to 10 family members and manage finances together, each from their own phone, all in real time.</p>
      </div>
      <div class="fp-pillar fp-reveal">
        <div class="fp-pillar-icon">📊</div>
        <h3 data-i18n="fp_pillar3_h">Insights that actually make sense</h3>
        <p data-i18n="fp_pillar3_p">Know exactly where your money goes, how much you can safely spend today, and what your balance will look like in 90 days.</p>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════════════
     CINEMA SECTION — Sticky scroll Apple style
══════════════════════════════════════════════════════════ -->
<section class="fp-cinema-outer" id="cinema">
  <div class="fp-cinema-sticky">
    <div class="fp-cinema-left">
      <!-- Slide 0 -->
      <div class="fp-slide active" data-slide="0">
        <div class="fp-slide-badge" data-i18n="fp_s0_badge">Dashboard</div>
        <h2 data-i18n-html="fp_s0_h">Everything at a glance.<br>Nothing left unseen.</h2>
        <p data-i18n="fp_s0_p">A fully customisable dashboard with 13 widgets — balance, spending flow, budget progress, savings goals and a 90-day projection of your account. Configure it once, never lose track again.</p>
        <ul class="fp-slide-list">
          <li data-i18n="fp_s0_l1">13 configurable widgets</li>
          <li data-i18n="fp_s0_l2">Spending flow breakdown by category</li>
          <li data-i18n="fp_s0_l3">Monthly income vs expenses chart</li>
        </ul>
      </div>
      <!-- Slide 1 -->
      <div class="fp-slide" data-slide="1">
        <div class="fp-slide-badge" data-i18n="fp_s1_badge">Transactions</div>
        <h2 data-i18n-html="fp_s1_h">Every euro.<br>Tracked, categorised, understood.</h2>
        <p data-i18n="fp_s1_p">Add expenses and income in seconds. Powerful filters, CSV import from your bank, automatic transfer tracking — and a reconciliation tool to match your statement line by line.</p>
        <ul class="fp-slide-list">
          <li data-i18n="fp_s1_l1">Import CSV from 10+ bank profiles</li>
          <li data-i18n="fp_s1_l2">3-level category hierarchy</li>
          <li data-i18n="fp_s1_l3">Statement reconciliation with lock badge</li>
        </ul>
      </div>
      <!-- Slide 2 -->
      <div class="fp-slide" data-slide="2">
        <div class="fp-slide-badge" data-i18n="fp_s2_badge">Budgets</div>
        <h2 data-i18n-html="fp_s2_h">Set a limit.<br>Respect it. Every month.</h2>
        <p data-i18n="fp_s2_p">Assign monthly budgets to any category. The app alerts you at 80% and 100% so you act before going over. Compare spent vs planned month by month.</p>
        <ul class="fp-slide-list">
          <li data-i18n="fp_s2_l1">Category budgets with smart alerts</li>
          <li data-i18n="fp_s2_l2">Visual spent-vs-planned bars</li>
          <li data-i18n="fp_s2_l3">Month-by-month history</li>
        </ul>
      </div>
      <!-- Slide 3 -->
      <div class="fp-slide" data-slide="3">
        <div class="fp-slide-badge" data-i18n="fp_s3_badge">Recurring</div>
        <h2 data-i18n-html="fp_s3_h">Rent, salary, subscriptions.<br>All on autopilot.</h2>
        <p data-i18n="fp_s3_p">Recurring transactions generate themselves at the right date. Installment plans split any purchase into monthly payments automatically tracked in your calendar.</p>
        <ul class="fp-slide-list">
          <li data-i18n="fp_s3_l1">Auto-generation at due date</li>
          <li data-i18n="fp_s3_l2">Instalment purchase tracking</li>
          <li data-i18n="fp_s3_l3">Calendar view of upcoming payments</li>
        </ul>
      </div>
      <!-- Slide 4 -->
      <div class="fp-slide" data-slide="4">
        <div class="fp-slide-badge" data-i18n="fp_s4_badge">Savings Goals</div>
        <h2 data-i18n-html="fp_s4_h">Dream it.<br>Plan it. Reach it.</h2>
        <p data-i18n="fp_s4_p">Create goals for holidays, emergency funds or big purchases. Track contributions over time and watch the progress bar fill up — without touching your real account balances.</p>
        <ul class="fp-slide-list">
          <li data-i18n="fp_s4_l1">Unlimited goals (Premium)</li>
          <li data-i18n="fp_s4_l2">Contribution history</li>
          <li data-i18n="fp_s4_l3">Target date and pause/complete</li>
        </ul>
      </div>
      <!-- Slide 5 -->
      <div class="fp-slide" data-slide="5">
        <div class="fp-slide-badge" data-i18n="fp_s5_badge">Survival Line</div>
        <h2 data-i18n-html="fp_s5_h">See your future balance.<br>Act before it's too late.</h2>
        <p data-i18n="fp_s5_p">The 90-day projection combines your recurring transactions, scheduled payments and credit card billing dates to show exactly where your balance is headed — and whether you're safe to spend today.</p>
        <ul class="fp-slide-list">
          <li data-i18n="fp_s5_l1">90-day forward computation</li>
          <li data-i18n="fp_s5_l2">Safe-to-spend daily figure</li>
          <li data-i18n="fp_s5_l3">Credit card billing date awareness</li>
        </ul>
      </div>
    </div>
    <div class="fp-cinema-right">
      <div class="fp-cinema-phone">
        <div class="fp-cp-notch"></div>
        <div class="fp-cp-inner" id="cinemaPhoneInner">
          <!-- Screen 0: Dashboard -->
          <div class="fp-cscreen active" data-screen="0">
            <div class="fp-cs-header fp-cs-navy">
              <div class="fp-cs-h-top"><span>FamlyBudget</span><span data-i18n="fp_ph_date">May 2026</span></div>
              <div class="fp-cs-balance-label" data-i18n="fp_ph_balance_label">Total balance</div>
              <div class="fp-cs-balance">€ 8,420.50</div>
            </div>
            <div class="fp-cs-body">
              <div class="fp-cs-row">
                <div class="fp-cs-card"><div class="fp-cs-clabel" data-i18n="fp_ph_income">Income</div><div class="fp-cs-cval fp-green">+€3,200</div></div>
                <div class="fp-cs-card"><div class="fp-cs-clabel" data-i18n="fp_ph_expenses">Expenses</div><div class="fp-cs-cval fp-red">−€1,847</div></div>
              </div>
              <div class="fp-cs-widget-title" data-i18n="fp_cs0_trend">6-month trend</div>
              <div class="fp-cs-bars">
                <div class="fp-cs-bar-grp"><div class="fp-cs-b fp-cs-b-i" style="height:22px"></div><div class="fp-cs-b fp-cs-b-e" style="height:16px"></div></div>
                <div class="fp-cs-bar-grp"><div class="fp-cs-b fp-cs-b-i" style="height:28px"></div><div class="fp-cs-b fp-cs-b-e" style="height:14px"></div></div>
                <div class="fp-cs-bar-grp"><div class="fp-cs-b fp-cs-b-i" style="height:20px"></div><div class="fp-cs-b fp-cs-b-e" style="height:24px"></div></div>
                <div class="fp-cs-bar-grp"><div class="fp-cs-b fp-cs-b-i" style="height:32px"></div><div class="fp-cs-b fp-cs-b-e" style="height:18px"></div></div>
                <div class="fp-cs-bar-grp"><div class="fp-cs-b fp-cs-b-i" style="height:26px"></div><div class="fp-cs-b fp-cs-b-e" style="height:12px"></div></div>
                <div class="fp-cs-bar-grp"><div class="fp-cs-b fp-cs-b-i" style="height:36px"></div><div class="fp-cs-b fp-cs-b-e" style="height:20px"></div></div>
              </div>
              <div class="fp-cs-widget-title" data-i18n="fp_cs0_spending">Top spending</div>
              <div class="fp-cs-spend-row"><span class="fp-cs-spend-cat" data-i18n="fp_cs0_food">🛒 Food</span><div class="fp-cs-spend-bar-wrap"><div class="fp-cs-spend-bar" style="width:72%"></div></div><span class="fp-cs-spend-val">€532</span></div>
              <div class="fp-cs-spend-row"><span class="fp-cs-spend-cat">🏠 Home</span><div class="fp-cs-spend-bar-wrap"><div class="fp-cs-spend-bar" style="width:55%"></div></div><span class="fp-cs-spend-val">€750</span></div>
              <div class="fp-cs-spend-row"><span class="fp-cs-spend-cat" data-i18n="fp_cs0_car">🚗 Car</span><div class="fp-cs-spend-bar-wrap"><div class="fp-cs-spend-bar" style="width:38%"></div></div><span class="fp-cs-spend-val">€280</span></div>
            </div>
          </div>
          <!-- Screen 1: Transactions -->
          <div class="fp-cscreen" data-screen="1">
            <div class="fp-cs-header fp-cs-navy">
              <div class="fp-cs-h-top"><span data-i18n="fp_s1_badge">Transactions</span></div>
              <div class="fp-cs-chips">
                <span class="fp-chip active" data-i18n="fp_c_all">All</span>
                <span class="fp-chip" data-i18n="fp_c_out">Expenses</span>
                <span class="fp-chip" data-i18n="fp_c_in">Income</span>
              </div>
            </div>
            <div class="fp-cs-body">
              <div class="fp-cs-group-label" data-i18n="fp_c_today">TODAY</div>
              <div class="fp-cs-tx"><div class="fp-cs-tx-icon" style="background:#FEF3C7">🛒</div><div class="fp-cs-tx-info"><b data-i18n="fp_tx1">Grocery</b><span data-i18n="fp_tx1_cat">Food</span></div><span class="fp-red fp-cs-tx-amt">−€94.30</span></div>
              <div class="fp-cs-tx"><div class="fp-cs-tx-icon" style="background:#FEE2E2">⛽</div><div class="fp-cs-tx-info"><b data-i18n="fp_c_fuel">Fuel</b><span data-i18n="fp_c_car">Car</span></div><span class="fp-red fp-cs-tx-amt">−€58.00</span></div>
              <div class="fp-cs-group-label" data-i18n="fp_c_yesterday">YESTERDAY</div>
              <div class="fp-cs-tx"><div class="fp-cs-tx-icon" style="background:#DCFCE7">💼</div><div class="fp-cs-tx-info"><b data-i18n="fp_tx2">Salary</b><span data-i18n="fp_c_work">Work</span></div><span class="fp-green fp-cs-tx-amt">+€2,400</span></div>
              <div class="fp-cs-tx"><div class="fp-cs-tx-icon" style="background:#EDE9FE">🎬</div><div class="fp-cs-tx-info"><b>Netflix</b><span data-i18n="fp_c_sub">Subscription</span></div><span class="fp-red fp-cs-tx-amt">−€15.99</span></div>
              <div class="fp-cs-tx fp-cs-tx-reconciled"><div class="fp-cs-tx-icon" style="background:#F0FDF4">🏠</div><div class="fp-cs-tx-info"><b data-i18n="fp_tx3">Rent</b><span>🔒</span></div><span class="fp-red fp-cs-tx-amt">−€750</span></div>
            </div>
          </div>
          <!-- Screen 2: Budget -->
          <div class="fp-cscreen" data-screen="2">
            <div class="fp-cs-header fp-cs-navy">
              <div class="fp-cs-h-top"><span data-i18n="fp_s2_badge">Budgets</span><span data-i18n="fp_ph_date">May 2026</span></div>
              <div class="fp-cs-balance-label" data-i18n="fp_cs2_total">Total budget</div>
              <div class="fp-cs-balance">€ 2,500</div>
            </div>
            <div class="fp-cs-body">
              <div class="fp-cs-budget-item">
                <div class="fp-bud-row"><span>🛒</span><span data-i18n="fp_tx1_cat">Food</span><span class="fp-bud-pct">72%</span></div>
                <div class="fp-bud-track"><div class="fp-bud-fill fp-bud-ok" style="width:72%"></div></div>
                <div class="fp-bud-vals"><span>€360 / €500</span></div>
              </div>
              <div class="fp-cs-budget-item">
                <div class="fp-bud-row"><span>🏠</span><span data-i18n="fp_tx3_cat">Home</span><span class="fp-bud-pct fp-red">103%</span></div>
                <div class="fp-bud-track"><div class="fp-bud-fill fp-bud-over" style="width:100%"></div></div>
                <div class="fp-bud-vals"><span>€824 / €800</span><span class="fp-bud-alert">⚠️ Over</span></div>
              </div>
              <div class="fp-cs-budget-item">
                <div class="fp-bud-row"><span>🚗</span><span data-i18n="fp_c_car">Car</span><span class="fp-bud-pct">56%</span></div>
                <div class="fp-bud-track"><div class="fp-bud-fill fp-bud-ok" style="width:56%"></div></div>
                <div class="fp-bud-vals"><span>€280 / €500</span></div>
              </div>
              <div class="fp-cs-budget-item">
                <div class="fp-bud-row"><span>🎉</span><span data-i18n="fp_c_leisure">Leisure</span><span class="fp-bud-pct fp-orange">81%</span></div>
                <div class="fp-bud-track"><div class="fp-bud-fill fp-bud-warn" style="width:81%"></div></div>
                <div class="fp-bud-vals"><span>€243 / €300</span><span class="fp-bud-alert fp-orange" data-i18n="fp_bud_almost">Almost there</span></div>
              </div>
            </div>
          </div>
          <!-- Screen 3: Recurring -->
          <div class="fp-cscreen" data-screen="3">
            <div class="fp-cs-header fp-cs-navy">
              <div class="fp-cs-h-top"><span data-i18n="fp_s3_badge">Recurring</span></div>
            </div>
            <div class="fp-cs-body">
              <div class="fp-cs-rec-item"><div class="fp-cs-tx-icon" style="background:#EDE9FE">🏠</div><div class="fp-cs-tx-info"><b data-i18n="fp_tx3">Rent</b><span data-i18n="fp_rec_monthly">Monthly · 1st</span></div><span class="fp-red fp-cs-tx-amt">−€750</span></div>
              <div class="fp-cs-rec-item"><div class="fp-cs-tx-icon" style="background:#DCFCE7">💼</div><div class="fp-cs-tx-info"><b data-i18n="fp_tx2">Salary</b><span data-i18n="fp_rec_27">Monthly · 27th</span></div><span class="fp-green fp-cs-tx-amt">+€2,400</span></div>
              <div class="fp-cs-rec-item"><div class="fp-cs-tx-icon" style="background:#EDE9FE">🎬</div><div class="fp-cs-tx-info"><b>Netflix</b><span data-i18n="fp_rec_monthly">Monthly · 1st</span></div><span class="fp-red fp-cs-tx-amt">−€15.99</span></div>
              <div class="fp-cs-rec-item"><div class="fp-cs-tx-icon" style="background:#FEF3C7">📦</div><div class="fp-cs-tx-info"><b>Amazon Prime</b><span data-i18n="fp_rec_yearly">Yearly · Jan</span></div><span class="fp-red fp-cs-tx-amt">−€49.90</span></div>
              <div class="fp-cs-group-label" style="margin-top:10px" data-i18n="fp_rec_installments">INSTALLMENTS</div>
              <div class="fp-cs-rec-item"><div class="fp-cs-tx-icon" style="background:#FEF9C3">📱</div><div class="fp-cs-tx-info"><b data-i18n="fp_rec_phone">New phone</b><span>3 / 12</span></div><span class="fp-red fp-cs-tx-amt">−€49.17</span></div>
            </div>
          </div>
          <!-- Screen 4: Savings Goals -->
          <div class="fp-cscreen" data-screen="4">
            <div class="fp-cs-header fp-cs-navy">
              <div class="fp-cs-h-top"><span data-i18n="fp_s4_badge">Savings Goals</span></div>
            </div>
            <div class="fp-cs-body">
              <div class="fp-cs-goal">
                <div class="fp-goal-row"><span>✈️</span><span data-i18n="fp_goal_vacation">Vacation 2026</span><span class="fp-goal-pct">40%</span></div>
                <div class="fp-goal-track"><div class="fp-goal-fill" style="width:40%;background:#3B82F6"></div></div>
                <div class="fp-goal-vals"><span>€1,200 / €3,000</span><span class="fp-goal-eta" data-i18n="fp_goal_eta_aug">Aug 2026</span></div>
              </div>
              <div class="fp-cs-goal">
                <div class="fp-goal-row"><span>🚨</span><span data-i18n="fp_goal_emergency">Emergency Fund</span><span class="fp-goal-pct">68%</span></div>
