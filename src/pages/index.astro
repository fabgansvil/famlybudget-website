---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="FamlyBudget — Family finances, finally under control"
  description="FamlyBudget — Track income and expenses, manage shared budgets and sync your entire household in real time. Free to start."
>

  <!-- ══════════ HERO ══════════ -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-eyebrow" data-i18n="hero_eyebrow">✦ New 2026</div>
        <h1 data-i18n-html="hero_h1">Family finances,<br /><span>finally under control</span></h1>
        <p class="hero-sub" data-i18n="hero_sub">Track income and expenses, manage shared budgets, visualize clear charts and sync your entire household in real time.</p>
        <div class="hero-buttons">
          <a href="#download" class="gplay-badge" id="download">
            <span class="badge-icon">▶</span>
            <span class="badge-text">
              <span class="badge-sub" data-i18n="hero_badge_sub">Get it on</span>
              <span class="badge-store" data-i18n="hero_badge_store">Google Play</span>
            </span>
          </a>
          <a href="#features" class="btn btn-secondary btn-lg" data-i18n="hero_explore">Explore features</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-num" data-i18n="stat1_num">100%</span>
            <span class="stat-label" data-i18n="stat1_label">Free to start</span>
          </div>
          <div class="stat">
            <span class="stat-num" data-i18n="stat2_num">5 languages</span>
            <span class="stat-label" data-i18n="stat2_label">IT · EN · ES · FR · HE</span>
          </div>
          <div class="stat">
            <span class="stat-num" data-i18n="stat3_num">Offline</span>
            <span class="stat-label" data-i18n="stat3_label">Works without internet</span>
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="phone-float-card phone-float-1">
          <div class="fc-label" data-i18n="phone_float1_label">Monthly savings</div>
          <div class="fc-val">+ €340</div>
        </div>
        <div class="phone">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="phone-header">
              <div class="phone-header-top">
                <span>FamlyBudget</span>
                <span data-i18n="phone_month">April 2026</span>
              </div>
              <div class="phone-greeting" data-i18n="phone_greeting">Hello, Fabrizio 👋</div>
              <div class="phone-balance-label" data-i18n="phone_balance_label">Total account balance</div>
              <div class="phone-balance">€ 8,420.50</div>
            </div>
            <div class="phone-cards-row">
              <div class="phone-card">
                <div class="phone-card-label" data-i18n="phone_income">Income</div>
                <div class="phone-card-value income">+€3,200</div>
              </div>
              <div class="phone-card">
                <div class="phone-card-label" data-i18n="phone_expenses">Expenses</div>
                <div class="phone-card-value expense">−€1,847</div>
              </div>
            </div>
            <div class="phone-section-title" data-i18n="phone_latest_tx">Latest transactions</div>
            <div class="phone-tx">
              <div class="phone-tx-left">
                <div class="phone-tx-icon" style="background:#FEF3C7;">🛒</div>
                <div>
                  <div class="phone-tx-name" data-i18n="phone_tx1_name">Grocery</div>
                  <div class="phone-tx-cat" data-i18n="phone_tx1_cat">Food</div>
                </div>
              </div>
              <div class="phone-tx-amount neg">−€94.30</div>
            </div>
            <div class="phone-tx">
              <div class="phone-tx-left">
                <div class="phone-tx-icon" style="background:#DCFCE7;">💼</div>
                <div>
                  <div class="phone-tx-name" data-i18n="phone_tx2_name">Salary</div>
                  <div class="phone-tx-cat" data-i18n="phone_tx2_cat">Income</div>
                </div>
              </div>
              <div class="phone-tx-amount pos">+€2,400</div>
            </div>
            <div class="phone-tx">
              <div class="phone-tx-left">
                <div class="phone-tx-icon" style="background:#EDE9FE;">🏠</div>
                <div>
                  <div class="phone-tx-name" data-i18n="phone_tx3_name">Rent</div>
                  <div class="phone-tx-cat" data-i18n="phone_tx3_cat">Home</div>
                </div>
              </div>
              <div class="phone-tx-amount neg">−€750</div>
            </div>
            <div class="phone-chart">
              <div class="phone-chart-label" data-i18n="phone_chart_label">6-month trend</div>
              <div class="phone-bars">
                <div class="phone-bar-group"><div class="phone-bar bar-income" style="height:28px;"></div><div class="phone-bar bar-expense" style="height:22px;"></div></div>
                <div class="phone-bar-group"><div class="phone-bar bar-income" style="height:32px;"></div><div class="phone-bar bar-expense" style="height:18px;"></div></div>
                <div class="phone-bar-group"><div class="phone-bar bar-income" style="height:24px;"></div><div class="phone-bar bar-expense" style="height:30px;"></div></div>
                <div class="phone-bar-group"><div class="phone-bar bar-income" style="height:36px;"></div><div class="phone-bar bar-expense" style="height:20px;"></div></div>
                <div class="phone-bar-group"><div class="phone-bar bar-income" style="height:30px;"></div><div class="phone-bar bar-expense" style="height:16px;"></div></div>
                <div class="phone-bar-group"><div class="phone-bar bar-income" style="height:40px;"></div><div class="phone-bar bar-expense" style="height:24px;"></div></div>
              </div>
            </div>
          </div>
        </div>
        <div class="phone-float-card phone-float-2">
          <div class="phone-float-2-icon">🎯</div>
          <div class="phone-float-2-text">
            <div class="fc-label" data-i18n="phone_float2_label">Vacation goal</div>
            <div class="fc-val">€ 1,200 / €3,000</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ FEATURES ══════════ -->
  <section class="section" id="features">
    <div class="container">
      <div class="section-header">
        <div class="badge" data-i18n="feat_badge">✦ Features</div>
        <h2 data-i18n="feat_h2">Everything you need to manage the family budget</h2>
        <p data-i18n="feat_p">A complete yet simple tool, designed for real everyday life.</p>
      </div>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <div class="feature-body">
            <h3 data-i18n="feat1_h3">Charts &amp; Reports</h3>
            <p data-i18n="feat1_p">Analyze income and expenses with interactive monthly charts and discover exactly where your money goes.</p>
            <ul class="feature-bullets">
              <li data-i18n="feat1_b1">Monthly bar charts with account and category filters</li>
              <li data-i18n="feat1_b2">90-day balance projection</li>
              <li data-i18n="feat1_b3">CSV and PDF data export (Premium)</li>
            </ul>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">☁️</div>
          <div class="feature-body">
            <h3 data-i18n="feat2_h3">Real-time Cloud Sync</h3>
            <p data-i18n="feat2_p">Data syncs instantly across all household devices. Always up to date, wherever you are.</p>
            <ul class="feature-bullets">
              <li data-i18n="feat2_b1">Real-time updates without reloading</li>
              <li data-i18n="feat2_b2">Available in the Premium Cloud plan</li>
              <li data-i18n="feat2_b3">Offline mode: the app works without internet</li>
            </ul>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">👨‍👩‍👧</div>
          <div class="feature-body">
            <h3 data-i18n="feat3_h3">Family Multi-user</h3>
            <p data-i18n="feat3_p">Invite family members and manage the budget together, each from their own smartphone.</p>
            <ul class="feature-bullets">
              <li data-i18n="feat3_b1">Up to 10 members in Premium Cloud plan</li>
              <li data-i18n="feat3_b2">Each member adds expenses in real time</li>
              <li data-i18n="feat3_b3">Shared view of accounts and transactions</li>
            </ul>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">💳</div>
          <div class="feature-body">
            <h3 data-i18n="feat4_h3">Accounts &amp; Credit Cards</h3>
            <p data-i18n="feat4_p">Keep track of all your financial tools in one place, with always up-to-date balances.</p>
            <ul class="feature-bullets">
              <li data-i18n="feat4_b1">Current accounts, cash, savings accounts</li>
              <li data-i18n="feat4_b2">Credit cards with statement and billing dates</li>
              <li data-i18n="feat4_b3">Balance adjustable with opening date</li>
            </ul>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">🎯</div>
          <div class="feature-body">
            <h3 data-i18n="feat5_h3">Savings Goals</h3>
            <p data-i18n="feat5_p">Set financial milestones and monitor progress over time, contribution by contribution.</p>
            <ul class="feature-bullets">
              <li data-i18n="feat5_b1">Holidays, purchases, emergency funds</li>
              <li data-i18n="feat5_b2">Manual contributions with history</li>
              <li data-i18n="feat5_b3">Visual progress bar with completion %</li>
            </ul>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">🔁</div>
          <div class="feature-body">
            <h3 data-i18n="feat6_h3">Recurring Transactions</h3>
            <p data-i18n="feat6_p">Subscriptions, salaries and rent generate automatically. Never miss an expense again.</p>
            <ul class="feature-bullets">
              <li data-i18n="feat6_b1">Automatic generation at due date</li>
              <li data-i18n="feat6_b2">Installment support with payment plans</li>
              <li data-i18n="feat6_b3">Up to 4 recurring in Free plan, unlimited in Premium</li>
            </ul>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">🏦</div>
          <div class="feature-body">
            <h3 data-i18n="feat7_h3">Monthly Budgets</h3>
            <p data-i18n="feat7_p">Set a budget for each category and monitor in real time how much you have already spent against the limit.</p>
            <ul class="feature-bullets">
              <li data-i18n="feat7_b1">Budget per category with overspending alerts</li>
              <li data-i18n="feat7_b2">Spent vs planned comparison</li>
              <li data-i18n="feat7_b3">Month-by-month budget history</li>
            </ul>
          </div>
        </div>

        <div class="feature-card">
          <div class="feature-icon">🔒</div>
          <div class="feature-body">
            <h3 data-i18n="feat8_h3">Privacy &amp; Security</h3>
            <p data-i18n="feat8_p">Your financial data is protected. You can choose to never send it to the cloud if you prefer maximum privacy.</p>
            <ul class="feature-bullets">
              <li data-i18n="feat8_b1">App lock with fingerprint or Face ID</li>
              <li data-i18n="feat8_b2">Local mode: data only on device</li>
              <li data-i18n="feat8_b3">No financial data shared with third parties</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════ SCREENSHOTS ══════════ -->
  <section class="section section-alt" id="screenshots">
    <div class="container">
      <div class="section-header">
        <div class="badge" data-i18n="ss_badge">✦ Interface</div>
        <h2 data-i18n="ss_h2">An interface designed for simplicity</h2>
        <p data-i18n="ss_p">Clean, fast, intuitive. All the important information always at your fingertips.</p>
      </div>
      <div class="screenshots-row">

        <div class="screenshot-item">
          <div class="phone-sm">
            <div class="phone-sm-notch"></div>
            <div class="phone-sm-body">
              <div class="ss-header">
                <h4>Dashboard</h4>
                <div class="ss-balance">€ 8,420.50</div>
              </div>
              <div class="ss-row">
                <div class="ss-pill"><div class="p-label" data-i18n="ss1_income">Income</div><div class="p-val" style="color:#16a34a">+3,200€</div></div>
                <div class="ss-pill"><div class="p-label" data-i18n="ss1_expenses">Expenses</div><div class="p-val" style="color:#dc2626">−1,847€</div></div>
              </div>
              <div class="ss-mini-bar-wrap">
                <div class="ss-mini-bar-title" data-i18n="ss1_last4">Last 4 months</div>
                <div class="ss-mini-bars">
                  <div class="ss-mb i" style="height:20px;"></div><div class="ss-mb e" style="height:14px;"></div>
                  <div class="ss-mb i" style="height:24px;"></div><div class="ss-mb e" style="height:18px;"></div>
                  <div class="ss-mb i" style="height:18px;"></div><div class="ss-mb e" style="height:22px;"></div>
                  <div class="ss-mb i" style="height:30px;"></div><div class="ss-mb e" style="height:16px;"></div>
                </div>
              </div>
              <div class="ss-tx-item"><div style="display:flex;align-items:center"><div class="ss-tx-icon2" style="background:#FEF3C7">🛒</div><span class="ss-tx-name2" style="margin-left:6px" data-i18n="phone_tx1_name">Grocery</span></div><span class="ss-tx-amt" style="color:#dc2626">−€94</span></div>
              <div class="ss-tx-item"><div style="display:flex;align-items:center"><div class="ss-tx-icon2" style="background:#DCFCE7">💼</div><span class="ss-tx-name2" style="margin-left:6px" data-i18n="phone_tx2_name">Salary</span></div><span class="ss-tx-amt" style="color:#16a34a">+€2400</span></div>
              <div class="ss-tx-item"><div style="display:flex;align-items:center"><div class="ss-tx-icon2" style="background:#EDE9FE">🏠</div><span class="ss-tx-name2" style="margin-left:6px" data-i18n="phone_tx3_name">Rent</span></div><span class="ss-tx-amt" style="color:#dc2626">−€750</span></div>
            </div>
          </div>
          <div class="caption" data-i18n="ss1_caption">Main dashboard</div>
        </div>

        <div class="screenshot-item">
          <div class="phone-sm featured">
            <div class="phone-sm-notch"></div>
            <div class="phone-sm-body">
              <div class="ss2-header"><h4 data-i18n="ss2_header">Transactions</h4></div>
              <div class="ss2-filter">
                <div class="ss2-chip active" data-i18n="ss2_all">All</div>
                <div class="ss2-chip" data-i18n="ss2_out">Expenses</div>
                <div class="ss2-chip" data-i18n="ss2_in">Income</div>
              </div>
              <div class="ss2-group-label" data-i18n="ss2_today">TODAY</div>
              <div class="ss2-tx"><div class="ss2-tx-icon" style="background:#FEF3C7">🛒</div><div class="ss2-tx-info"><div class="ss2-tx-name" data-i18n="phone_tx1_name">Grocery</div><div class="ss2-tx-meta" data-i18n="ss2_tx1_cat">Food</div></div><div class="ss2-tx-amt" style="color:#dc2626">−€94.30</div></div>
              <div class="ss2-tx"><div class="ss2-tx-icon" style="background:#FEE2E2">⛽</div><div class="ss2-tx-info"><div class="ss2-tx-name" data-i18n="ss2_tx2">Gas</div><div class="ss2-tx-meta" data-i18n="ss2_tx2_cat">Car</div></div><div class="ss2-tx-amt" style="color:#dc2626">−€58.00</div></div>
              <div style="margin-top:6px;" class="ss2-group-label" data-i18n="ss2_yesterday">YESTERDAY</div>
              <div class="ss2-tx"><div class="ss2-tx-icon" style="background:#DCFCE7">💼</div><div class="ss2-tx-info"><div class="ss2-tx-name" data-i18n="phone_tx2_name">Salary</div><div class="ss2-tx-meta" data-i18n="ss2_tx3_cat">Work</div></div><div class="ss2-tx-amt" style="color:#16a34a">+€2,400</div></div>
              <div class="ss2-tx"><div class="ss2-tx-icon" style="background:#EDE9FE">🎬</div><div class="ss2-tx-info"><div class="ss2-tx-name">Netflix</div><div class="ss2-tx-meta" data-i18n="ss2_tx4_cat">Subscription</div></div><div class="ss2-tx-amt" style="color:#dc2626">−€15.99</div></div>
              <div class="ss2-tx"><div class="ss2-tx-icon" style="background:#FEF9C3">🍕</div><div class="ss2-tx-info"><div class="ss2-tx-name" data-i18n="ss2_tx5">Restaurant</div><div class="ss2-tx-meta" data-i18n="ss2_tx5_cat">Leisure</div></div><div class="ss2-tx-amt" style="color:#dc2626">−€42.00</div></div>
            </div>
          </div>
          <div class="caption" style="color:var(--blue-dark);font-weight:700;" data-i18n="ss2_caption">Transaction list</div>
        </div>

        <div class="screenshot-item">
          <div class="phone-sm">
            <div class="phone-sm-notch"></div>
            <div class="phone-sm-body">
              <div class="ss3-header"><h4 data-i18n="ss3_header">Reports</h4></div>
              <div class="ss3-period">
                <div class="ss3-chip active" data-i18n="ss3_3m">3 months</div>
                <div class="ss3-chip" data-i18n="ss3_6m">6 months</div>
                <div class="ss3-chip" data-i18n="ss3_year">Year</div>
              </div>
              <div class="ss3-summary">
                <div class="ss3-sum-row"><span class="ss3-sum-label" data-i18n="ss3_income">Tot. Income</span><span class="ss3-sum-val" style="color:#16a34a">+€9,600</span></div>
                <div class="ss3-sum-row"><span class="ss3-sum-label" data-i18n="ss3_expenses">Tot. Expenses</span><span class="ss3-sum-val" style="color:#dc2626">−€5,541</span></div>
                <div class="ss3-sum-row"><span class="ss3-sum-label" data-i18n="ss3_savings">Net savings</span><span class="ss3-sum-val" style="color:#1E3A8A">+€4,059</span></div>
              </div>
              <div class="ss3-bar-chart">
                <div class="ss3-bar-title" data-i18n="ss3_chart_title">Income vs Expenses</div>
                <div class="ss3-bars">
                  <div class="ss3-bar-grp"><div class="bars"><div class="ss3-b i" style="height:32px;"></div><div class="ss3-b e" style="height:20px;"></div></div><div class="ss3-month">FEB</div></div>
                  <div class="ss3-bar-grp"><div class="bars"><div class="ss3-b i" style="height:28px;"></div><div class="ss3-b e" style="height:24px;"></div></div><div class="ss3-month">MAR</div></div>
                  <div class="ss3-bar-grp"><div class="bars"><div class="ss3-b i" style="height:36px;"></div><div class="ss3-b e" style="height:18px;"></div></div><div class="ss3-month">APR</div></div>
                </div>
              </div>
            </div>
          </div>
          <div class="caption" data-i18n="ss3_caption">Charts &amp; reports</div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════ PRICING ══════════ -->
  <section class="section" id="pricing">
    <div class="container">
      <div class="section-header">
        <div class="badge" data-i18n="pr_badge">✦ Pricing</div>
        <h2 data-i18n="pr_h2">Choose the right plan for you</h2>
        <p data-i18n="pr_p">Start for free. Choose Premium based on how you want to store your data.</p>
      </div>
      <div class="pricing-grid">

        <div class="pricing-card">
          <div class="pricing-name" data-i18n="pr_free_name">Free</div>
          <div class="pricing-price">€0<span data-i18n="pr_free_price_suffix">/month</span></div>
          <div class="pricing-yearly" data-i18n="pr_free_yearly">Free forever</div>
          <div class="pricing-divider"></div>
          <ul class="pricing-features">
            <li data-i18n-html="pr_free_f1"><span class="check">✓</span> Local <strong>or</strong> cloud storage of your choice</li>
            <li data-i18n-html="pr_free_f2"><span class="check">✓</span> Up to 80 transactions/month</li>
            <li data-i18n-html="pr_free_f3"><span class="check">✓</span> 3 active accounts</li>
            <li data-i18n-html="pr_free_f4"><span class="check">✓</span> 4 active recurring transactions</li>
            <li data-i18n-html="pr_free_f5"><span class="check">✓</span> 15 additional categories</li>
            <li data-i18n-html="pr_free_f6"><span class="check">✓</span> Basic charts &amp; reports</li>
            <li class="muted" data-i18n-html="pr_free_f7"><span class="cross">✕</span> Backup &amp; Restore</li>
            <li class="muted" data-i18n-html="pr_free_f8"><span class="cross">✕</span> Unlimited accounts</li>
            <li class="muted" data-i18n-html="pr_free_f9"><span class="cross">✕</span> Data export</li>
            <li class="muted" data-i18n-html="pr_free_f10"><span class="cross">✕</span> Multi-device sync</li>
          </ul>
          <a href="#download" class="btn btn-secondary" style="width:100%;justify-content:center;margin-top:auto;" data-i18n="pr_free_btn">Start Free</a>
        </div>

        <div class="pricing-card">
          <div class="pricing-name" data-i18n="pr_local_name">Premium Local</div>
          <div class="pricing-price">€2<span data-i18n="pr_local_price_suffix">/month</span></div>
          <div class="pricing-yearly" data-i18n-html="pr_local_yearly">or <strong>€15/year — save 38%</strong></div>
          <div class="pricing-divider"></div>
          <div style="display:flex;align-items:center;gap:8px;background:var(--neutral);border-radius:10px;padding:10px 12px;margin-bottom:16px;">
            <span style="font-size:22px;">📱</span>
            <div>
              <div style="font-size:12px;font-weight:700;color:var(--text);" data-i18n="pr_local_badge_title">Data on device</div>
              <div style="font-size:11px;color:var(--text-muted);" data-i18n="pr_local_badge_sub">Your data stays only on the device — no financial data in the cloud</div>
            </div>
          </div>
          <ul class="pricing-features">
            <li data-i18n-html="pr_local_f1"><span class="check">✓</span> Unlimited transactions</li>
            <li data-i18n-html="pr_local_f2"><span class="check">✓</span> Up to 20 active accounts</li>
            <li data-i18n-html="pr_local_f3"><span class="check">✓</span> Unlimited recurring transactions</li>
            <li data-i18n-html="pr_local_f4"><span class="check">✓</span> 150 additional categories</li>
            <li data-i18n-html="pr_local_f5"><span class="check">✓</span> Advanced charts &amp; reports</li>
