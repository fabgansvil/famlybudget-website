<!-- ═══════════════════════════════════════════════════════════
     PAGE-SPECIFIC STYLES
═══════════════════════════════════════════════════════════ -->
<style>
  /* ── Variables override for dark sections ─── */
  :root {
    --fp-dark: #0B1120;
    --fp-dark-2: #111827;
    --fp-dark-3: #1E293B;
    --fp-accent: #3B82F6;
    --fp-accent-2: #6366F1;
    --fp-green: #10B981;
    --fp-red: #EF4444;
    --fp-orange: #F59E0B;
    --fp-text-light: rgba(255,255,255,0.92);
    --fp-text-muted-dark: rgba(255,255,255,0.5);
    --fp-radius: 16px;
    --fp-radius-lg: 24px;
  }

  /* ── Utility ─────────────────────────────── */
  .fp-green { color: var(--fp-green); }
  .fp-red   { color: var(--fp-red); }
  .fp-orange{ color: var(--fp-orange); }

  .fp-gradient-text {
    background: linear-gradient(90deg, #60A5FA, #818CF8, #A78BFA);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Reveal animation ────────────────────── */
  .fp-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .fp-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ════════════════════ HERO ════════════════ */
  .fp-hero {
    position: relative;
    background: var(--fp-dark);
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 100px 0 60px;
  }
  .fp-hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(99,102,241,0.18) 0%, transparent 70%);
  }
  .fp-hero-glow {
    position: absolute; border-radius: 50%;
    filter: blur(80px); pointer-events: none;
  }
  .fp-hero-glow-1 {
    width: 600px; height: 600px;
    top: -200px; right: -100px;
    background: radial-gradient(circle, rgba(59,130,246,0.15) 0%, transparent 70%);
    animation: fp-float 8s ease-in-out infinite;
  }
  .fp-hero-glow-2 {
    width: 400px; height: 400px;
    bottom: -100px; left: -50px;
    background: radial-gradient(circle, rgba(99,102,241,0.12) 0%, transparent 70%);
    animation: fp-float 10s ease-in-out infinite reverse;
  }
  @keyframes fp-float {
    0%, 100% { transform: translateY(0) scale(1); }
    50%       { transform: translateY(-20px) scale(1.03); }
  }

  .fp-hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .fp-hero-content {
    animation: fp-hero-in 0.9s ease both;
  }
  @keyframes fp-hero-in {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .fp-eyebrow {
    display: inline-flex; align-items: center;
    background: rgba(59,130,246,0.15);
    border: 1px solid rgba(59,130,246,0.3);
    color: #93C5FD;
    font-size: 12px; font-weight: 700;
    padding: 5px 14px; border-radius: 99px;
    margin-bottom: 24px; letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .fp-hero-h1 {
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 800;
    line-height: 1.1;
    color: var(--fp-text-light);
    margin-bottom: 24px;
    letter-spacing: -1px;
  }
  .fp-hero-sub {
    font-size: 18px;
    color: var(--fp-text-muted-dark);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 480px;
  }
  .fp-hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }

  /* ── Hero Phone ──────────────────────────── */
  .fp-hero-phone-wrap {
    position: relative;
    display: flex;
    justify-content: center;
    animation: fp-hero-phone-in 1s 0.2s ease both;
  }
  @keyframes fp-hero-phone-in {
    from { opacity: 0; transform: translateY(50px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .fp-hero-phone {
    width: 270px;
    background: #0F172A;
    border-radius: 48px;
    border: 1.5px solid rgba(255,255,255,0.1);
    box-shadow:
      0 0 0 1px rgba(59,130,246,0.2),
      0 40px 80px rgba(0,0,0,0.6),
      0 0 60px rgba(59,130,246,0.1);
    overflow: hidden;
    position: relative;
  }
  .fp-phone-notch {
    width: 100px; height: 26px;
    background: #000;
    border-radius: 0 0 18px 18px;
    margin: 0 auto;
  }
  .fp-phone-inner { padding: 0; }
  .fp-phone-header {
    background: linear-gradient(135deg, #1E3A8A 0%, #1E40AF 100%);
    padding: 14px 16px 16px;
    color: #fff;
  }
  .fp-ph-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .fp-ph-greeting { font-size: 13px; font-weight: 700; }
  .fp-ph-date { font-size: 10px; opacity: 0.6; }
  .fp-ph-label { font-size: 10px; opacity: 0.65; margin-bottom: 4px; }
  .fp-ph-balance { font-size: 26px; font-weight: 800; margin-bottom: 12px; }
  .fp-ph-stats { display: flex; gap: 12px; }
  .fp-ph-stat { display: flex; align-items: center; gap: 6px; }
  .fp-ph-stat-icon {
    width: 22px; height: 22px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800;
  }
  .fp-income-icon { background: rgba(16,185,129,0.2); color: var(--fp-green); }
  .fp-expense-icon { background: rgba(239,68,68,0.2); color: var(--fp-red); }
  .fp-ph-stat-label { font-size: 8px; opacity: 0.65; }
  .fp-ph-stat-val { font-size: 11px; font-weight: 700; }

  .fp-phone-body { padding: 12px 14px; background: #0F172A; }
  .fp-survival-widget {
    background: #1E293B;
    border-radius: 12px;
    padding: 10px;
    margin-bottom: 10px;
    border: 1px solid rgba(255,255,255,0.06);
  }
  .fp-sw-title { font-size: 8px; color: rgba(255,255,255,0.5); margin-bottom: 6px; }
  .fp-sw-chart { height: 40px; }
  .fp-sw-svg { width: 100%; height: 40px; }
  .fp-sw-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 6px; }
  .fp-sw-safe { font-size: 8px; color: rgba(255,255,255,0.5); }
  .fp-sw-amount { font-size: 13px; font-weight: 800; color: var(--fp-green); }

  .fp-phone-txlist { display: flex; flex-direction: column; gap: 0; }
  .fp-ptx {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .fp-ptx:last-child { border-bottom: none; }
  .fp-ptx-icon {
    width: 26px; height: 26px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; flex-shrink: 0;
  }
  .fp-ptx-info { flex: 1; display: flex; flex-direction: column; }
  .fp-ptx-info span:first-child { font-size: 10px; font-weight: 600; color: rgba(255,255,255,0.9); }
  .fp-ptx-cat { font-size: 8px; color: rgba(255,255,255,0.4); }
  .fp-ptx-amt { font-size: 10px; font-weight: 700; }

  /* ── Floating badges ─────────────────────── */
  .fp-float {
    position: absolute;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 14px;
    padding: 10px 14px;
    display: flex; align-items: center; gap: 10px;
    color: #fff;
    white-space: nowrap;
  }
  .fp-float-a { top: 40px; right: -24px; }
  .fp-float-b { bottom: 60px; left: -24px; }
  .fp-float-icon { font-size: 20px; }
  .fp-float-label { font-size: 9px; color: rgba(255,255,255,0.5); }
  .fp-float-val { font-size: 12px; font-weight: 700; }

  .fp-scroll-hint {
    position: absolute; bottom: 32px; left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }
  .fp-scroll-dot {
    width: 6px; height: 6px;
    background: rgba(255,255,255,0.4);
    border-radius: 50%;
    animation: fp-scroll-bounce 1.6s ease-in-out infinite;
  }
  @keyframes fp-scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.4; }
    50%       { transform: translateY(8px); opacity: 1; }
  }

