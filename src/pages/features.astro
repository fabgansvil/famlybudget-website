  var saveBadge= document.querySelector('.fp-save-badge');
  var amounts  = document.querySelectorAll('.fp-pcard-amount[data-monthly]');
  var yearlyHints  = document.querySelectorAll('.fp-yearly-hint');
  var monthlyHints = document.querySelectorAll('.fp-monthly-hint');
  var isYearly = false;

  if (toggle) {
    toggle.addEventListener('click', function() {
      isYearly = !isYearly;
      toggle.classList.toggle('yearly', isYearly);
      saveBadge.classList.toggle('visible', isYearly);
      amounts.forEach(function(el) {
        el.textContent = isYearly ? el.getAttribute('data-yearly') : el.getAttribute('data-monthly');
      });
      yearlyHints.forEach(function(el)  { el.style.display = isYearly ? 'block' : 'none'; });
      monthlyHints.forEach(function(el) { el.style.display = isYearly ? 'none' : 'block'; });
    });
  }

