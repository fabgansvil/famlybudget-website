      </div>
      <a href="/#features" class="mobile-nav-link" data-i18n="nav_features">Features</a>
      <a href="/#screenshots" class="mobile-nav-link" data-i18n="nav_screenshots">Screenshots</a>
      <a href="/#pricing" class="mobile-nav-link" data-i18n="nav_pricing">Pricing</a>
      <div class="mobile-nav-divider"></div>
      <div class="mobile-lang">
        <span class="mobile-lang-label">Language</span>
        <div class="lang-switcher">
          <button class="lang-btn active" data-lang="en">EN</button>
          <button class="lang-btn" data-lang="it">IT</button>
